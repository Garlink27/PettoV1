<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PettoV1.ViewModels"
             xmlns:models="clr-namespace:SharedResources.Models;assembly=SharedResources"
             x:Class="PettoV1.Views.Categoria"
             x:DataType="vm:CategoriaViewModel"
             Title="Categoría">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource GradientStart}" Offset="0.0"/>
            <GradientStop Color="{StaticResource GradientMid}"   Offset="0.4"/>
            <GradientStop Color="{StaticResource GradientEnd}"   Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- ── Header glass ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="12,44,12,10"
              BackgroundColor="{StaticResource GlassHeaderBackground}">
            <ImageButton Grid.Column="0" Source="arrow_left_icon.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="Transparent"
                         Command="{Binding RegresarCommand}"/>
            <Label Grid.Column="1"
                   Text="{Binding FechaHora}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontSize="13" TextColor="{StaticResource TextOnDarkSecondary}"/>
            <ImageButton Grid.Column="2" Source="user_icon.png"
                         WidthRequest="44" HeightRequest="44"
                         BackgroundColor="{StaticResource GlassCardBackground}"
                         CornerRadius="22"/>
        </Grid>

        <!-- ── Contenido ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Título de categoría + menú opciones -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="{Binding Categoria.Nombre}"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="{StaticResource TextOnDark}"
                           VerticalOptions="Center"/>
                    <ImageButton Grid.Column="1"
                                 Source="more_icon.png"
                                 WidthRequest="32" HeightRequest="32"
                                 BackgroundColor="Transparent"/>
                </Grid>

                <!-- Tareas pendientes -->
                <Label Text="PENDIENTES"
                       FontSize="10" FontAttributes="Bold"
                       CharacterSpacing="1.5"
                       TextColor="{StaticResource AccentCyan}"/>

                <Frame Style="{StaticResource GlassCard}" Padding="12,4">
                    <CollectionView ItemsSource="{Binding TareasIncompletas}">
                        <CollectionView.EmptyView>
                            <Label Text="Sin tareas pendientes"
                                   TextColor="{StaticResource TextOnDarkSecondary}"
                                   FontSize="14" HorizontalOptions="Center" Margin="0,8"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TareaModel">
                                <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,8">
                                    <Border Grid.Column="0"
                                            WidthRequest="28" HeightRequest="28"
                                            BackgroundColor="{StaticResource GlassCardBackground}"
                                            Stroke="{StaticResource AccentCyan}"
                                            StrokeThickness="1.5">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}},
                                                                  Path=ToggleCompletadaCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="{Binding Titulo}"
                                           FontSize="15" TextColor="{StaticResource TextOnDark}"
                                           VerticalOptions="Center" Margin="10,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}},
                                                                  Path=VerDetalleTareaCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>
                                    <BoxView Grid.ColumnSpan="3"
                                             HeightRequest="1"
                                             BackgroundColor="{StaticResource GlassHeaderBackground}"
                                             VerticalOptions="End"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>

                <!-- Tareas completadas -->
                <Label Text="COMPLETADAS"
                       FontSize="10" FontAttributes="Bold"
                       CharacterSpacing="1.5"
                       TextColor="{StaticResource AccentCyan}"
                       Margin="0,4,0,0"/>

                <Frame Style="{StaticResource GlassCard}" Padding="12,4">
                    <CollectionView ItemsSource="{Binding TareasCompletadas}">
                        <CollectionView.EmptyView>
                            <Label Text="Sin tareas completadas"
                                   TextColor="{StaticResource TextOnDarkSecondary}"
                                   FontSize="14" HorizontalOptions="Center" Margin="0,8"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TareaModel">
                                <Grid ColumnDefinitions="Auto,*" Padding="0,8">
                                    <Border Grid.Column="0"
                                            WidthRequest="28" HeightRequest="28"
                                            BackgroundColor="{StaticResource AccentCyan}"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6"/>
                                        </Border.StrokeShape>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}},
                                                                  Path=ToggleCompletadaCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>
                                    </Border>
                                    <Label Grid.Column="1"
                                           Text="{Binding Titulo}"
                                           FontSize="15"
                                           TextColor="{StaticResource TextOnDarkSecondary}"
                                           TextDecorations="Strikethrough"
                                           VerticalOptions="Center"
                                           Margin="10,0"/>
                                    <BoxView Grid.ColumnSpan="2"
                                             HeightRequest="1"
                                             BackgroundColor="{StaticResource GlassHeaderBackground}"
                                             VerticalOptions="End"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Botón flotante Agregar tarea -->
        <Ellipse Grid.Row="1"
                 WidthRequest="60" HeightRequest="60"
                 HorizontalOptions="End"
                 VerticalOptions="End"
                 Margin="0,0,20,20">
            <Ellipse.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource AccentBlue}" Offset="0"/>
                    <GradientStop Color="{StaticResource AccentCyan}" Offset="1"/>
                </LinearGradientBrush>
            </Ellipse.Fill>
            <Ellipse.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding AgregarTareaCommand}"/>
            </Ellipse.GestureRecognizers>
        </Ellipse>
        <Label Grid.Row="1"
               Text="+"
               FontSize="32" TextColor="White"
               HorizontalOptions="End"
               VerticalOptions="End"
               Margin="0,0,32,24"
               InputTransparent="True"/>

    </Grid>
</ContentPage>
