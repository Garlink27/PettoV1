<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PettoV1.ViewModels"
             xmlns:models="clr-namespace:SharedResources.Models;assembly=SharedResources"
             x:Class="PettoV1.Views.Categoria"
             x:DataType="vm:CategoriaViewModel"
             Title="Categoría">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource GradientStart}" Offset="0.0"/>
            <GradientStop Color="{StaticResource GradientMid}"   Offset="0.4"/>
            <GradientStop Color="{StaticResource GradientEnd}"   Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <!-- Row 0: Header  |  Row 1: Scrollable content + FAB  |  Row 2: Selection action bar -->
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

        <!-- ── Header glass ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="12,44,12,10"
              BackgroundColor="{StaticResource GlassHeaderBackground}">
            <ImageButton Grid.Column="0" Source="arrow_left_icon.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="Transparent"
                         Command="{Binding RegresarCommand}"/>
            <Label Grid.Column="1"
                   Text="{Binding FechaHora}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontSize="13" TextColor="{StaticResource TextOnDarkSecondary}"/>
            <ImageButton Grid.Column="2" Source="user_icon.png"
                         WidthRequest="44" HeightRequest="44"
                         BackgroundColor="{StaticResource GlassCardBackground}"
                         CornerRadius="22"/>
        </Grid>

        <!-- ── Contenido ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="16">

                <!-- Título de categoría + menú opciones (3 puntos) -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="{Binding Categoria.Nombre}"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="{StaticResource TextOnDark}"
                           VerticalOptions="Center"/>
                    <ImageButton Grid.Column="1"
                                 Source="more_icon.png"
                                 WidthRequest="32" HeightRequest="32"
                                 BackgroundColor="Transparent"
                                 Command="{Binding AbrirMenuOpcionesCommand}"/>
                </Grid>

                <!-- ── PENDIENTES ── -->
                <Label Text="PENDIENTES"
                       FontSize="10" FontAttributes="Bold"
                       CharacterSpacing="1.5"
                       TextColor="{StaticResource AccentCyan}"/>

                <Frame Style="{StaticResource GlassCard}" Padding="12,4">
                    <CollectionView ItemsSource="{Binding TareasIncompletas}">
                        <CollectionView.EmptyView>
                            <Label Text="Sin tareas pendientes"
                                   TextColor="{StaticResource TextOnDarkSecondary}"
                                   FontSize="14" HorizontalOptions="Center" Margin="0,8"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TareaSeleccionableViewModel">
                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto"
                                      Padding="0,8,0,0">

                                    <!-- Checkbox column — stacks normal toggle + selection checkbox -->
                                    <Grid Grid.Column="0" Grid.Row="0"
                                          WidthRequest="28" HeightRequest="28"
                                          Margin="0,0,10,0"
                                          VerticalOptions="Center">

                                        <!-- Normal mode: tap = mark complete -->
                                        <Border WidthRequest="28" HeightRequest="28"
                                                BackgroundColor="{StaticResource GlassCardBackground}"
                                                Stroke="{StaticResource AccentCyan}"
                                                StrokeThickness="1.5"
                                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=NoModoSeleccion}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6"/>
                                            </Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=ToggleCompletadaCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Border>

                                        <!-- Selection mode: tap = toggle selection -->
                                        <Border WidthRequest="28" HeightRequest="28"
                                                BackgroundColor="Transparent"
                                                Stroke="{StaticResource AccentCyan}"
                                                StrokeThickness="1.5"
                                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=ModoSeleccion}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6"/>
                                            </Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding EsSeleccionada}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource AccentCyan}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="&#x2713;" FontSize="13" TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   IsVisible="{Binding EsSeleccionada}"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=ToggleSeleccionTareaCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Border>

                                    </Grid>

                                    <!-- Task title -->
                                    <Label Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Titulo}"
                                           FontSize="15"
                                           TextColor="{StaticResource TextOnDark}"
                                           VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=VerDetalleTareaCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <!-- Row separator -->
                                    <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                             HeightRequest="1"
                                             BackgroundColor="{StaticResource GlassHeaderBackground}"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>

                <!-- ── COMPLETADAS ── -->
                <Label Text="COMPLETADAS"
                       FontSize="10" FontAttributes="Bold"
                       CharacterSpacing="1.5"
                       TextColor="{StaticResource AccentCyan}"
                       Margin="0,4,0,0"/>

                <Frame Style="{StaticResource GlassCard}" Padding="12,4">
                    <CollectionView ItemsSource="{Binding TareasCompletadas}">
                        <CollectionView.EmptyView>
                            <Label Text="Sin tareas completadas"
                                   TextColor="{StaticResource TextOnDarkSecondary}"
                                   FontSize="14" HorizontalOptions="Center" Margin="0,8"/>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:TareaSeleccionableViewModel">
                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto"
                                      Padding="0,8,0,0">

                                    <!-- Checkbox column -->
                                    <Grid Grid.Column="0" Grid.Row="0"
                                          WidthRequest="28" HeightRequest="28"
                                          Margin="0,0,10,0"
                                          VerticalOptions="Center">

                                        <!-- Normal mode: filled = completed, tap = mark incomplete -->
                                        <Border WidthRequest="28" HeightRequest="28"
                                                BackgroundColor="{StaticResource AccentCyan}"
                                                StrokeThickness="0"
                                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=NoModoSeleccion}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6"/>
                                            </Border.StrokeShape>
                                            <Label Text="&#x2713;" FontSize="13" TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=ToggleCompletadaCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Border>

                                        <!-- Selection mode: tap = toggle selection -->
                                        <Border WidthRequest="28" HeightRequest="28"
                                                BackgroundColor="Transparent"
                                                Stroke="{StaticResource AccentCyan}"
                                                StrokeThickness="1.5"
                                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=ModoSeleccion}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="6"/>
                                            </Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border"
                                                             Binding="{Binding EsSeleccionada}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{StaticResource AccentCyan}"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="&#x2713;" FontSize="13" TextColor="White"
                                                   HorizontalOptions="Center" VerticalOptions="Center"
                                                   IsVisible="{Binding EsSeleccionada}"/>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=ToggleSeleccionTareaCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                        </Border>

                                    </Grid>

                                    <!-- Task title (strikethrough) -->
                                    <Label Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Titulo}"
                                           FontSize="15"
                                           TextColor="{StaticResource TextOnDarkSecondary}"
                                           TextDecorations="Strikethrough"
                                           VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriaViewModel}}, Path=VerDetalleTareaCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Label.GestureRecognizers>
                                    </Label>

                                    <!-- Row separator -->
                                    <BoxView Grid.Row="1" Grid.ColumnSpan="2"
                                             HeightRequest="1"
                                             BackgroundColor="{StaticResource GlassHeaderBackground}"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── FAB agregar tarea (hidden in selection mode) ── -->
        <Ellipse Grid.Row="1"
                 WidthRequest="60" HeightRequest="60"
                 HorizontalOptions="End"
                 VerticalOptions="End"
                 Margin="0,0,20,20"
                 IsVisible="{Binding NoModoSeleccion}">
            <Ellipse.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource AccentBlue}" Offset="0"/>
                    <GradientStop Color="{StaticResource AccentCyan}" Offset="1"/>
                </LinearGradientBrush>
            </Ellipse.Fill>
            <Ellipse.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding AgregarTareaCommand}"/>
            </Ellipse.GestureRecognizers>
        </Ellipse>
        <Label Grid.Row="1"
               Text="+"
               FontSize="32" TextColor="White"
               HorizontalOptions="End"
               VerticalOptions="End"
               Margin="0,0,32,24"
               InputTransparent="True"
               IsVisible="{Binding NoModoSeleccion}"/>

        <!-- ── Barra de acciones (solo visible en modo selección) ── -->
        <Grid Grid.Row="2"
              IsVisible="{Binding ModoSeleccion}"
              BackgroundColor="{StaticResource GlassHeaderBackground}"
              Padding="12,10">

            <!-- Modo Eliminar / Incompleto / Completado → Cancelar + Aceptar -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8"
                  IsVisible="{Binding MostrarBotonAceptar}">
                <Button Grid.Column="0"
                        Text="Cancelar"
                        Style="{StaticResource OutlineButton}"
                        Command="{Binding CancelarSeleccionCommand}"/>
                <Button Grid.Column="1"
                        Text="Aceptar"
                        Command="{Binding AceptarSeleccionCommand}"/>
            </Grid>

            <!-- Modo Seleccionar todas → 3 acciones + Cancelar -->
            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding MostrarBotonesMultiples}">
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                    <Button Grid.Column="0"
                            Text="Eliminar"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding EliminarSeleccionCommand}"/>
                    <Button Grid.Column="1"
                            Text="En curso"
                            Command="{Binding IncompletoSeleccionCommand}"/>
                    <Button Grid.Column="2"
                            Text="Completar"
                            Command="{Binding CompletoSeleccionCommand}"/>
                </Grid>
                <Button Text="Cancelar"
                        Style="{StaticResource OutlineButton}"
                        Command="{Binding CancelarSeleccionCommand}"/>
            </VerticalStackLayout>

        </Grid>

    </Grid>
</ContentPage>