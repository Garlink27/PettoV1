<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PettoV1.ViewModels"
             x:Class="PettoV1.Views.Configuracion"
             x:DataType="vm:ConfiguracionViewModel"
             BackgroundColor="#D5F9FF"
             Title="Configuraciones">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="12,44,12,10" BackgroundColor="#D5F9FF">
            <ImageButton Grid.Column="0" Source="arrow_left_icon.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="Transparent"
                         Command="{Binding RegresarCommand}"/>
            <Label Grid.Column="1"
                   Text="Configuraciones"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontSize="20" FontAttributes="Bold"
                   TextColor="#2C2C2C"/>
        </Grid>

        <!-- ── Contenido ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="0">

                <!-- ── Sección Idioma ── -->
                <Grid ColumnDefinitions="*,Auto"
                      Padding="0,18,0,18">
                    <Label Grid.Column="0"
                           Text="Idioma"
                           FontSize="16" TextColor="#2C2C2C"
                           VerticalOptions="Center"/>
                    <ImageButton Grid.Column="1"
                                 Source="arrow_right_icon.png"
                                 WidthRequest="28" HeightRequest="28"
                                 BackgroundColor="Transparent"/>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GuardarIdiomaCommand}"/>
                    </Grid.GestureRecognizers>
                </Grid>
                <BoxView HeightRequest="1" Color="#80DEEA"/>

                <!-- Selector de idioma -->
                <Picker ItemsSource="{Binding Idiomas}"
                        SelectedItem="{Binding IdiomaSeleccionado}"
                        TextColor="#2C2C2C"
                        BackgroundColor="White"
                        Margin="0,10,0,10"/>

                <Button Text="Guardar idioma"
                        BackgroundColor="#26C6DA"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="44"
                        Command="{Binding GuardarIdiomaCommand}"
                        Margin="0,0,0,24"/>

                <BoxView HeightRequest="1" Color="#80DEEA"/>

                <!-- ── Sección Cambiar contraseña ── -->
                <Grid ColumnDefinitions="*,Auto"
                      Padding="0,18,0,18">
                    <Label Grid.Column="0"
                           Text="Cambiar contraseña"
                           FontSize="16" TextColor="#2C2C2C"
                           VerticalOptions="Center"/>
                    <ImageButton Grid.Column="1"
                                 Source="arrow_right_icon.png"
                                 WidthRequest="28" HeightRequest="28"
                                 BackgroundColor="Transparent"/>
                </Grid>
                <BoxView HeightRequest="1" Color="#80DEEA" Margin="0,0,0,16"/>

                <!-- Contraseña actual -->
                <Label Text="Contraseña actual" FontSize="14" TextColor="#607D8B"/>
                <Entry Placeholder="Ingresa tu contraseña actual"
                       Text="{Binding ContrasenaActual}"
                       IsPassword="True"
                       TextColor="#1E1E1E"
                       PlaceholderColor="#B3B3B3"
                       BackgroundColor="White"
                       Margin="0,4,0,4">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsContrasenaActualValida}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsContrasenaActualValida}" Value="True">
                            <Setter Property="BackgroundColor" Value="White"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
                <Label Text="La contraseña actual es incorrecta"
                       TextColor="Red" FontSize="12" IsVisible="False">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsContrasenaActualValida}" Value="False">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsContrasenaActualValida}" Value="True">
                            <Setter Property="IsVisible" Value="False"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <!-- Nueva contraseña -->
                <Label Text="Nueva contraseña" FontSize="14" TextColor="#607D8B" Margin="0,10,0,0"/>
                <Entry Placeholder="Mínimo 6 caracteres"
                       Text="{Binding NuevaContrasena}"
                       IsPassword="True"
                       TextColor="#1E1E1E"
                       PlaceholderColor="#B3B3B3"
                       BackgroundColor="White"
                       Margin="0,4,0,4">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsNuevaContrasenaValida}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsNuevaContrasenaValida}" Value="True">
                            <Setter Property="BackgroundColor" Value="White"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>

                <!-- Confirmar nueva contraseña -->
                <Label Text="Confirmar nueva contraseña" FontSize="14" TextColor="#607D8B" Margin="0,10,0,0"/>
                <Entry Placeholder="Repite la nueva contraseña"
                       Text="{Binding ConfirmarNuevaContrasena}"
                       IsPassword="True"
                       TextColor="#1E1E1E"
                       PlaceholderColor="#B3B3B3"
                       BackgroundColor="White"
                       Margin="0,4,0,4">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsNuevaContrasenaValida}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsNuevaContrasenaValida}" Value="True">
                            <Setter Property="BackgroundColor" Value="White"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
                <Label Text="Las contraseñas no coinciden o son muy cortas"
                       TextColor="Red" FontSize="12" IsVisible="False">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsNuevaContrasenaValida}" Value="False">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsNuevaContrasenaValida}" Value="True">
                            <Setter Property="IsVisible" Value="False"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <!-- Botón Guardar contraseña -->
                <Button Text="Cambiar contraseña"
                        BackgroundColor="#2C2C2C"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="50"
                        IsEnabled="{Binding IsFormCambioValido}"
                        Command="{Binding CambiarContrasenaCommand}"
                        Margin="0,16,0,24">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFormCambioValido}" Value="False">
                            <Setter Property="BackgroundColor" Value="#9E9E9E"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFormCambioValido}" Value="True">
                            <Setter Property="BackgroundColor" Value="#2C2C2C"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <BoxView HeightRequest="1" Color="#80DEEA"/>

                <!-- Cerrar sesión -->
                <Button Text="Cerrar sesión"
                        BackgroundColor="#E53935"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="50"
                        Command="{Binding CerrarSesionCommand}"
                        Margin="0,24,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
