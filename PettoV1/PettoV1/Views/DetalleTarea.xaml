<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PettoV1.ViewModels"
             x:Class="PettoV1.Views.DetalleTarea"
             x:DataType="vm:DetalleTareaViewModel"
             Title="Detalle de Tarea">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource GradientStart}" Offset="0.0"/>
            <GradientStop Color="{StaticResource GradientMid}"   Offset="0.4"/>
            <GradientStop Color="{StaticResource GradientEnd}"   Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- ── Header glass ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="12,44,12,10"
              BackgroundColor="{StaticResource GlassHeaderBackground}">
            <ImageButton Grid.Column="0" Source="arrow_left_icon.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="Transparent"
                         Command="{Binding RegresarCommand}"/>
            <Label Grid.Column="1"
                   Text="{Binding FechaLimite, StringFormat='{0:dd/MM/yyyy}'}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontSize="13" TextColor="{StaticResource TextOnDarkSecondary}"/>
            <ImageButton Grid.Column="2" Source="more_icon.png"
                         WidthRequest="32" HeightRequest="32"
                         BackgroundColor="Transparent"
                         IsVisible="{Binding EsModoEdicion}"/>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="14">

                <!-- Título -->
                <Label Text="Título de la tarea" FontSize="13"
                       TextColor="{StaticResource TextOnDarkSecondary}"/>
                <Border BackgroundColor="{StaticResource GlassInputBackground}"
                        Stroke="{StaticResource GlassCardBorder}"
                        StrokeThickness="1" Padding="4,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding IsTituloValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="{StaticResource GlassInputInvalid}"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding IsTituloValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="{StaticResource GlassInputBackground}"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Entry Placeholder="Escribe el título"
                           Text="{Binding Titulo}"
                           FontSize="18"
                           BackgroundColor="Transparent"/>
                </Border>

                <BoxView HeightRequest="1" BackgroundColor="{StaticResource GlassHeaderBackground}"/>

                <!-- Fecha límite -->
                <Label Text="Fecha límite" FontSize="13"
                       TextColor="{StaticResource TextOnDarkSecondary}"/>
                <Frame Style="{StaticResource GlassCard}" Padding="12,4">
                    <DatePicker Date="{Binding FechaLimite}"
                                Format="dd/MM/yyyy"
                                TextColor="{StaticResource TextOnDark}"
                                BackgroundColor="Transparent"/>
                </Frame>

                <BoxView HeightRequest="1" BackgroundColor="{StaticResource GlassHeaderBackground}"/>

                <!-- Categoría -->
                <Label Text="Categoría" FontSize="13"
                       TextColor="{StaticResource TextOnDarkSecondary}"/>
                <Border BackgroundColor="{StaticResource GlassInputBackground}"
                        Stroke="{StaticResource GlassCardBorder}"
                        StrokeThickness="1" Padding="4,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Picker Title="Selecciona una categoría"
                            ItemsSource="{Binding Categorias}"
                            ItemDisplayBinding="{Binding Nombre}"
                            SelectedItem="{Binding CategoriaSeleccionada}"
                            TextColor="{StaticResource TextOnDark}"
                            BackgroundColor="Transparent"/>
                </Border>

                <BoxView HeightRequest="1" BackgroundColor="{StaticResource GlassHeaderBackground}"/>

                <!-- Descripción -->
                <Label Text="Descripción" FontSize="13"
                       TextColor="{StaticResource TextOnDarkSecondary}"/>
                <Frame Style="{StaticResource GlassCard}" Padding="12,8">
                    <Editor Placeholder="Agrega una descripción..."
                            Text="{Binding Descripcion}"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="80"
                            BackgroundColor="Transparent"/>
                </Frame>

                <BoxView HeightRequest="1" BackgroundColor="{StaticResource GlassHeaderBackground}"/>

                <!-- Completada -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Marcar como completada"
                           FontSize="15" TextColor="{StaticResource TextOnDark}"
                           VerticalOptions="Center"/>
                    <Switch Grid.Column="1" IsToggled="{Binding Completada}"
                            OnColor="{StaticResource AccentCyan}"/>
                </Grid>

                <!-- Guardar -->
                <Button Text="Guardar tarea"
                        IsEnabled="{Binding IsFormValid}"
                        Command="{Binding GuardarTareaCommand}"
                        Margin="0,16,0,0">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding IsFormValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#80607D8B"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Eliminar -->
                <Button Text="Eliminar tarea"
                        Style="{StaticResource DangerButton}"
                        IsVisible="{Binding EsModoEdicion}"
                        Command="{Binding EliminarTareaCommand}"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
