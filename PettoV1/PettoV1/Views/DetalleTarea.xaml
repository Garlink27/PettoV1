<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PettoV1.ViewModels"
             x:Class="PettoV1.Views.DetalleTarea"
             x:DataType="vm:DetalleTareaViewModel"
             BackgroundColor="#FFFFFF"
             Title="Detalle de Tarea">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="12,44,12,10" BackgroundColor="#E0F7FA">
            <ImageButton Grid.Column="0" Source="arrow_left_icon.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="Transparent"
                         Command="{Binding RegresarCommand}"/>
            <Label Grid.Column="1"
                   Text="{Binding FechaLimite, StringFormat='{0:dd/MM/yyyy}'}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontSize="13" TextColor="#006064"/>
            <ImageButton Grid.Column="2" Source="more_icon.png"
                         WidthRequest="32" HeightRequest="32"
                         BackgroundColor="Transparent"
                         IsVisible="{Binding EsModoEdicion}"/>
        </Grid>

        <!-- ── Formulario ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="14">

                <!-- Título -->
                <Label Text="Título de la tarea"
                       FontSize="14" TextColor="#546E7A"/>
                <Entry Placeholder="Escribe el título"
                       Text="{Binding Titulo}"
                       TextColor="#0D1B2A"
                       PlaceholderColor="#90A4AE"
                       FontSize="18"
                       BackgroundColor="#F5F5F5">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsTituloValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsTituloValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="#F5F5F5"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
                <Label Text="El título es requerido"
                       TextColor="#C62828" FontSize="12" IsVisible="False">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsTituloValid}" Value="False">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsTituloValid}" Value="True">
                            <Setter Property="IsVisible" Value="False"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <BoxView HeightRequest="1" Color="#E0E0E0"/>

                <!-- Fecha límite -->
                <Label Text="Fecha límite"
                       FontSize="14" TextColor="#546E7A"/>
                <DatePicker Date="{Binding FechaLimite}"
                            Format="dd/MM/yyyy"
                            TextColor="#0D1B2A"
                            BackgroundColor="#F5F5F5"/>

                <BoxView HeightRequest="1" Color="#E0E0E0"/>

                <!-- Descripción -->
                <Label Text="Descripción"
                       FontSize="14" TextColor="#546E7A"/>
                <Editor Placeholder="Agrega una descripción..."
                        Text="{Binding Descripcion}"
                        TextColor="#0D1B2A"
                        PlaceholderColor="#90A4AE"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="80"
                        BackgroundColor="#F5F5F5"/>

                <BoxView HeightRequest="1" Color="#E0E0E0"/>

                <!-- Completada -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="Marcar como completada"
                           FontSize="15" TextColor="#0D1B2A"
                           VerticalOptions="Center"/>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding Completada}"
                            OnColor="#006064"/>
                </Grid>

                <!-- Botones de acción -->
                <Button Text="Guardar tarea"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="50"
                        IsEnabled="{Binding IsFormValid}"
                        Command="{Binding GuardarTareaCommand}"
                        Margin="0,16,0,0">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFormValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#B0BEC5"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFormValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="#006064"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Eliminar tarea"
                        BackgroundColor="#D32F2F"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="50"
                        IsVisible="{Binding EsModoEdicion}"
                        Command="{Binding EliminarTareaCommand}"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
