<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PettoV1.ViewModels"
             x:Class="PettoV1.Views.DetalleTarea"
             x:DataType="vm:DetalleTareaViewModel"
             BackgroundColor="#D5F9FF"
             Title="Detalle de Tarea">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="12,44,12,10" BackgroundColor="#D5F9FF">
            <ImageButton Grid.Column="0" Source="arrow_left_icon.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="Transparent"
                         Command="{Binding RegresarCommand}"/>
            <Label Grid.Column="1"
                   Text="{Binding FechaLimite, StringFormat='{0:dd/MM/yyyy}'}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontSize="13" TextColor="#2C2C2C"/>
            <!-- Menú opciones (Eliminar / Editar) -->
            <ImageButton Grid.Column="2" Source="more_icon.png"
                         WidthRequest="32" HeightRequest="32"
                         BackgroundColor="Transparent"
                         IsVisible="{Binding EsModoEdicion}"/>
        </Grid>

        <!-- ── Formulario ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="14">

                <!-- Título -->
                <Label Text="Título de la tarea"
                       FontSize="14" TextColor="#607D8B"/>
                <Entry Placeholder="Escribe el título"
                       Text="{Binding Titulo}"
                       TextColor="#1E1E1E"
                       PlaceholderColor="#B3B3B3"
                       FontSize="18"
                       BackgroundColor="Transparent">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsTituloValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsTituloValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="Transparent"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
                <Label Text="El título es requerido"
                       TextColor="Red" FontSize="12" IsVisible="False">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsTituloValid}" Value="False">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsTituloValid}" Value="True">
                            <Setter Property="IsVisible" Value="False"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <BoxView HeightRequest="1" Color="#B0E0E6"/>

                <!-- Fecha límite -->
                <Label Text="Fecha límite"
                       FontSize="14" TextColor="#607D8B"/>
                <DatePicker Date="{Binding FechaLimite}"
                            Format="dd/MM/yyyy"
                            TextColor="#2C2C2C"
                            BackgroundColor="White"/>

                <BoxView HeightRequest="1" Color="#B0E0E6"/>

                <!-- Descripción -->
                <Label Text="Descripción"
                       FontSize="14" TextColor="#607D8B"/>
                <Editor Placeholder="Agrega una descripción..."
                        Text="{Binding Descripcion}"
                        TextColor="#1E1E1E"
                        PlaceholderColor="#B3B3B3"
                        AutoSize="TextChanges"
                        MinimumHeightRequest="80"
                        BackgroundColor="White"/>

                <BoxView HeightRequest="1" Color="#B0E0E6"/>

                <!-- Completada -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="Marcar como completada"
                           FontSize="15" TextColor="#2C2C2C"
                           VerticalOptions="Center"/>
                    <Switch Grid.Column="1"
                            IsToggled="{Binding Completada}"
                            OnColor="#26C6DA"/>
                </Grid>

                <!-- Botones de acción -->
                <Button Text="Guardar tarea"
                        BackgroundColor="#2C2C2C"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="50"
                        IsEnabled="{Binding IsFormValid}"
                        Command="{Binding GuardarTareaCommand}"
                        Margin="0,16,0,0">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFormValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#9E9E9E"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFormValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="#2C2C2C"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <Button Text="Eliminar tarea"
                        BackgroundColor="#E53935"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="50"
                        IsVisible="{Binding EsModoEdicion}"
                        Command="{Binding EliminarTareaCommand}"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
