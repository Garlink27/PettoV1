<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PettoV1.ViewModels"
             xmlns:models="clr-namespace:SharedResources.Models;assembly=SharedResources"
             x:Class="PettoV1.Views.HistorialTareas"
             x:DataType="vm:HistorialTareasViewModel"
             BackgroundColor="#FFFFFF"
             Title="Tu Archivo">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="12,44,12,10" BackgroundColor="#E0F7FA">
            <ImageButton Grid.Column="0" Source="menu_icon.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="Transparent"
                         Command="{Binding AbrirMenuCommand}"/>
            <Label Grid.Column="1"
                   Text="{Binding FechaHora}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontSize="13" TextColor="#006064"/>
            <ImageButton Grid.Column="2" Source="user_icon.png"
                         WidthRequest="44" HeightRequest="44"
                         BackgroundColor="#B2EBF2" CornerRadius="22"
                         Command="{Binding IrAPerfilCommand}"/>
        </Grid>

        <!-- ── Contenido ── -->
        <VerticalStackLayout Grid.Row="1" Spacing="0">

            <!-- Barra de herramientas: calendario + filtro -->
            <Grid ColumnDefinitions="Auto,*,Auto"
                  Padding="16,12" BackgroundColor="#F5F5F5">
                <ImageButton Grid.Column="0"
                             Source="calendar_icon.png"
                             WidthRequest="36" HeightRequest="36"
                             BackgroundColor="Transparent"
                             Command="{Binding ToggleCalendarioCommand}"/>
                <Label Grid.Column="1"
                       Text="Tu Archivo"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="#0D1B2A"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"/>
                <ImageButton Grid.Column="2"
                             Source="filter_icon.png"
                             WidthRequest="36" HeightRequest="36"
                             BackgroundColor="Transparent"
                             Command="{Binding FiltrarPorFechaCommand}"/>
            </Grid>

            <!-- Selector de fecha -->
            <DatePicker Date="{Binding FechaFiltro}"
                        Format="dd/MM/yyyy"
                        BackgroundColor="#F5F5F5"
                        TextColor="#0D1B2A"
                        Margin="16,0,16,8"
                        IsVisible="{Binding MostrarCalendario}"/>

            <!-- Notas / historial -->
            <ScrollView>
                <VerticalStackLayout Padding="16" Spacing="12">

                    <CollectionView ItemsSource="{Binding Historial}"
                                    EmptyView="No hay tareas completadas">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TareaModel">
                                <Frame BackgroundColor="#F5F5F5"
                                       CornerRadius="12"
                                       Padding="16"
                                       Margin="0,4"
                                       HasShadow="False">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Titulo}"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="#0D1B2A"/>
                                        <Label Text="{Binding Descripcion}"
                                               FontSize="13"
                                               TextColor="#546E7A"
                                               MaxLines="3"
                                               LineBreakMode="TailTruncation"/>
                                        <Label Text="{Binding FechaLimite, StringFormat='Completada: {0:dd/MM/yyyy}'}"
                                               FontSize="12"
                                               TextColor="#78909C"/>
                                        <Label Text="{Binding Categoria.Nombre}"
                                               FontSize="12"
                                               TextColor="#006064"
                                               FontAttributes="Bold"/>
                                    </VerticalStackLayout>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </ScrollView>

        </VerticalStackLayout>

    </Grid>
</ContentPage>
