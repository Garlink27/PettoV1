<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PettoV1.ViewModels"
             x:Class="PettoV1.Views.Perfil"
             x:DataType="vm:PerfilViewModel"
             BackgroundColor="#D5F9FF"
             Title="Perfil">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="12,44,12,10" BackgroundColor="#D5F9FF">
            <ImageButton Grid.Column="0" Source="arrow_left_icon.png"
                         WidthRequest="40" HeightRequest="40"
                         BackgroundColor="Transparent"
                         Command="{Binding RegresarCommand}"/>
            <Label Grid.Column="1"
                   Text="Perfil"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   FontSize="20" FontAttributes="Bold"
                   TextColor="#2C2C2C"/>
            <ImageButton Grid.Column="2" Source="settings_icon.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="Transparent"
                         Command="{Binding IrAConfiguracionCommand}"/>
        </Grid>

        <!-- ── Contenido ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20">

                <!-- Avatar -->
                <Grid HorizontalOptions="Center" WidthRequest="130" HeightRequest="130">
                    <Ellipse Fill="#B0E0E6"
                             WidthRequest="130" HeightRequest="130"/>
                    <Image Source="user_large_icon.png"
                           WidthRequest="90" HeightRequest="90"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <!-- Botón editar foto (ícono pequeño) -->
                    <ImageButton Source="edit_icon.png"
                                 WidthRequest="28" HeightRequest="28"
                                 BackgroundColor="White"
                                 CornerRadius="14"
                                 HorizontalOptions="End"
                                 VerticalOptions="End"/>
                </Grid>

                <!-- Nombre de usuario -->
                <Label Text="{Binding NombreUsuario}"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="#2C2C2C"
                       HorizontalOptions="Center"/>

                <!-- Sección Información -->
                <BoxView HeightRequest="1" Color="#80DEEA"/>

                <Label Text="Información"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="#2C2C2C"/>

                <!-- Email -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Email" FontSize="13" TextColor="#607D8B"/>
                    <Label Text="{Binding Email}"
                           FontSize="15" TextColor="#2C2C2C"/>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="#B0E0E6"/>

                <!-- Contraseña (solo muestra asteriscos) -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Contraseña" FontSize="13" TextColor="#607D8B"/>
                    <Label Text="••••••••"
                           FontSize="15" TextColor="#2C2C2C"/>
                </VerticalStackLayout>

                <BoxView HeightRequest="1" Color="#B0E0E6"/>

                <!-- Teléfono (editable) -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Teléfono" FontSize="13" TextColor="#607D8B"/>
                    <Entry Text="{Binding Telefono}"
                           Placeholder="Agrega tu teléfono"
                           Keyboard="Telephone"
                           TextColor="#2C2C2C"
                           PlaceholderColor="#B3B3B3"
                           BackgroundColor="White"/>
                </VerticalStackLayout>

                <!-- Botón Guardar -->
                <Button Text="Guardar cambios"
                        BackgroundColor="#2C2C2C"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="50"
                        Command="{Binding GuardarPerfilCommand}"
                        Margin="0,12,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
