<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PettoV1.Views.Registro"
             BackgroundColor="#FFFFFF"
             Title="Registro">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <Ellipse Fill="#B2EBF2"
                     WidthRequest="130" HeightRequest="130"
                     HorizontalOptions="Center"
                     Margin="0,50,0,20"/>

            <VerticalStackLayout Padding="24" Spacing="12">

                <Label Text="Crear cuenta"
                       FontSize="26" FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="#0D1B2A"
                       Margin="0,0,0,8"/>

                <!-- Correo -->
                <Label Text="Correo" FontSize="16" TextColor="#37474F"/>
                <Entry Placeholder="ejemplo@correo.com"
                       Keyboard="Email"
                       Text="{Binding Email}"
                       TextColor="#0D1B2A"
                       PlaceholderColor="#90A4AE"
                       BackgroundColor="#F5F5F5">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsEmailValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsEmailValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="#F5F5F5"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
                <Label Text="Ingresa un correo electrónico válido"
                       TextColor="#C62828" FontSize="12" IsVisible="False">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsEmailValid}" Value="False">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsEmailValid}" Value="True">
                            <Setter Property="IsVisible" Value="False"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <!-- Nombre de usuario -->
                <Label Text="Nombre de usuario" FontSize="16" TextColor="#37474F"/>
                <Entry Placeholder="Mínimo 3 caracteres"
                       Text="{Binding NombreUsuario}"
                       TextColor="#0D1B2A"
                       PlaceholderColor="#90A4AE"
                       BackgroundColor="#F5F5F5">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsUsernameValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsUsernameValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="#F5F5F5"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
                <Label Text="El nombre debe tener al menos 3 caracteres"
                       TextColor="#C62828" FontSize="12" IsVisible="False">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsUsernameValid}" Value="False">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsUsernameValid}" Value="True">
                            <Setter Property="IsVisible" Value="False"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <!-- Contraseña -->
                <Label Text="Contraseña" FontSize="16" TextColor="#37474F"/>
                <Entry Placeholder="Mínimo 6 caracteres con un número"
                       IsPassword="True"
                       Text="{Binding Contrasena}"
                       TextColor="#0D1B2A"
                       PlaceholderColor="#90A4AE"
                       BackgroundColor="#F5F5F5">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsPasswordValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsPasswordValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="#F5F5F5"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
                <Label Text="Mínimo 6 caracteres y al menos un número"
                       TextColor="#C62828" FontSize="12" IsVisible="False">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsPasswordValid}" Value="False">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsPasswordValid}" Value="True">
                            <Setter Property="IsVisible" Value="False"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <!-- Confirmar contraseña -->
                <Label Text="Confirmar contraseña" FontSize="16" TextColor="#37474F"/>
                <Entry Placeholder="Repite tu contraseña"
                       IsPassword="True"
                       Text="{Binding ConfirmarContrasena}"
                       TextColor="#0D1B2A"
                       PlaceholderColor="#90A4AE"
                       BackgroundColor="#F5F5F5">
                    <Entry.Triggers>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsConfirmPasswordValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Entry"
                                     Binding="{Binding IsConfirmPasswordValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="#F5F5F5"/>
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>
                <Label Text="Las contraseñas no coinciden"
                       TextColor="#C62828" FontSize="12" IsVisible="False">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsConfirmPasswordValid}" Value="False">
                            <Setter Property="IsVisible" Value="True"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label"
                                     Binding="{Binding IsConfirmPasswordValid}" Value="True">
                            <Setter Property="IsVisible" Value="False"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>

                <!-- Botón Registrarse -->
                <Button Text="Registrarse"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="50"
                        Command="{Binding RegistrarseCommand}"
                        Margin="0,8,0,0">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFormValid}" Value="False">
                            <Setter Property="BackgroundColor" Value="#B0BEC5"/>
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsFormValid}" Value="True">
                            <Setter Property="BackgroundColor" Value="#006064"/>
                            <Setter Property="IsEnabled" Value="True"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>

                <!-- Enlace Ingresar -->
                <Label HorizontalOptions="Center" Margin="0,4,0,0">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="¿Ya tienes cuenta? "
                                  TextColor="#37474F" FontSize="14"/>
                            <Span Text="Ingresar"
                                  TextColor="#0277BD" FontSize="14"
                                  TextDecorations="Underline">
                                <Span.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding IrALoginCommand}"/>
                                </Span.GestureRecognizers>
                            </Span>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
