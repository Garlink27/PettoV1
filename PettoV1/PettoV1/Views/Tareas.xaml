<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PettoV1.ViewModels"
             xmlns:models="clr-namespace:SharedResources.Models;assembly=SharedResources"
             x:Class="PettoV1.Views.Tareas"
             x:DataType="vm:TareasViewModel"
             BackgroundColor="#FFFFFF"
             Title="Tareas">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <!-- ── Header ── -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="12,44,12,10" BackgroundColor="#E0F7FA">
            <ImageButton Grid.Column="0" Source="menu_icon.png"
                         WidthRequest="36" HeightRequest="36"
                         BackgroundColor="Transparent"
                         Command="{Binding AbrirMenuCommand}"/>
            <Label Grid.Column="1"
                   Text="{Binding FechaHora}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   FontSize="13" TextColor="#006064"/>
            <ImageButton Grid.Column="2" Source="user_icon.png"
                         WidthRequest="44" HeightRequest="44"
                         BackgroundColor="#B2EBF2" CornerRadius="22"
                         Command="{Binding IrAPerfilCommand}"/>
        </Grid>

        <!-- ── Contenido ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="20">

                <!-- Tareas próximas -->
                <Label Text="Tareas próximas"
                       FontSize="18" FontAttributes="Bold" TextColor="#0D1B2A"/>

                <CollectionView ItemsSource="{Binding TareasProximas}"
                                EmptyView="No hay tareas próximas">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TareaModel">
                            <Grid Padding="0,4">
                                <BoxView HeightRequest="1" Color="#E0E0E0"
                                         VerticalOptions="End"/>
                                <Label Text="{Binding Titulo}"
                                       FontSize="15" TextColor="#0D1B2A"
                                       Padding="4,10"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Separador -->
                <BoxView HeightRequest="1" Color="#E0E0E0" Margin="0,4"/>

                <!-- Categorías (cuadrícula 2 columnas) -->
                <Label Text="Categorías"
                       FontSize="18" FontAttributes="Bold" TextColor="#0D1B2A"/>

                <CollectionView ItemsSource="{Binding Categorias}"
                                EmptyView="Sin categorías">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="2"
                                         HorizontalItemSpacing="10"
                                         VerticalItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:CategoriaModel">
                            <Frame BackgroundColor="#F5F5F5"
                                   CornerRadius="12"
                                   Padding="12"
                                   HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TareasViewModel}},
                                                          Path=VerCategoriaCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Frame.GestureRecognizers>
                                <Label Text="{Binding Nombre}"
                                       FontSize="15" TextColor="#0D1B2A"
                                       HorizontalOptions="Center"
                                       HorizontalTextAlignment="Center"/>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
